# ─── RoomRentKH Backend — Environment Variables ────────────────────────────────
# Copy this to .env for local development.
# On Railway: set these in Dashboard → Variables (NOT committed to git).

PORT=5000
NODE_ENV=development

# MongoDB Atlas URI
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://USERNAME:OVFFr3EjVQqORVsD@cluster0.xxxxx.mongodb.net/roomrentkh?retryWrites=true&w=majority

# JWT Secret — generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_long_random_string
JWT_EXPIRES_IN=7d

# Frontend origin for CORS (no trailing slash)
# Local dev:    http://localhost:5173
# Production:   https://roomrentkh.pages.dev   ← your Cloudflare Pages URL
FRONTEND_URL=http://localhost:5173
